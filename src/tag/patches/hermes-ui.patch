+def get_picker_provider_config(provider: str) -> Optional[ProviderConfig]:
+    """Return auth metadata for picker/dashboard provider setup flows.
+
+    This intentionally includes providers like OpenRouter that are NOT in
+    PROVIDER_REGISTRY because runtime resolution relies on treating them as
+    special cases. UI surfaces that need auth_type and env-var hints should use
+    this helper instead of reading PROVIDER_REGISTRY directly.
+    """
+    slug = (provider or "").strip().lower()
+    if not slug:
+        return None
+    return PROVIDER_REGISTRY.get(slug) or _PICKER_PROVIDER_FALLBACKS.get(slug)
+
+
