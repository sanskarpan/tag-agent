diff --git a/tests/gateway/test_model_picker_gateway.py b/tests/gateway/test_model_picker_gateway.py
new file mode 100644
index 000000000..d278f6935
--- /dev/null
+++ b/tests/gateway/test_model_picker_gateway.py
@@ -0,0 +1,75 @@
+from __future__ import annotations
+
+import importlib
+import os
+import sys
+
+from hermes_cli.inventory import ConfigContext
+
+
+def _reload_server(monkeypatch, hermes_home):
+    monkeypatch.setenv("HERMES_HOME", str(hermes_home))
+    monkeypatch.delenv("HERMES_MANAGED", raising=False)
+    sys.modules.pop("tui_gateway.server", None)
+    import tui_gateway.server as server
+
+    return importlib.reload(server)
+
+
+def test_model_save_key_supports_openrouter_fallback(monkeypatch, tmp_path):
+    server = _reload_server(monkeypatch, tmp_path)
+    monkeypatch.setattr(
+        "hermes_cli.inventory.load_picker_context",
+        lambda: ConfigContext(
+            current_provider="",
+            current_model="",
+            current_base_url="",
+            user_providers={},
+            custom_providers=[],
+        ),
+    )
+    monkeypatch.setattr(
+        "hermes_cli.inventory.build_models_payload",
+        lambda ctx, **kwargs: {
+            "providers": [
+                {
+                    "slug": "openrouter",
+                    "name": "OpenRouter",
+                    "models": ["anthropic/claude-haiku-4.5"],
+                    "total_models": 1,
+                    "authenticated": True,
+                }
+            ]
+        },
+    )
+
+    result = server._methods["model.save_key"](
+        "rid-1",
+        {"slug": "openrouter", "api_key": "sk-or-test-key"},
+    )
+
+    assert "error" not in result
+    provider = result["result"]["provider"]
+    assert provider["slug"] == "openrouter"
+    assert provider["authenticated"] is True
+    assert (tmp_path / ".env").read_text(encoding="utf-8") == "OPENROUTER_API_KEY=sk-or-test-key\n"
+    assert os.environ["OPENROUTER_API_KEY"] == "sk-or-test-key"
+
+
+def test_model_disconnect_removes_openrouter_fallback_env(monkeypatch, tmp_path):
+    server = _reload_server(monkeypatch, tmp_path)
+    env_path = tmp_path / ".env"
+    env_path.write_text("OPENROUTER_API_KEY=sk-or-test-key\nKEEP_ME=1\n", encoding="utf-8")
+    monkeypatch.setenv("OPENROUTER_API_KEY", "sk-or-test-key")
+    monkeypatch.setattr("hermes_cli.auth.clear_provider_auth", lambda slug: False)
+
