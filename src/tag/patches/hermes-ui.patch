new file mode 100644
index 000000000..1ae715bc7
--- /dev/null
+++ b/ui-tui/src/__tests__/brandingBanner.test.tsx
@@ -0,0 +1,162 @@
+import { renderSync } from '@hermes/ink'
+import React from 'react'
+import { readFileSync } from 'node:fs'
+import { resolve } from 'node:path'
+import { PassThrough } from 'node:stream'
+import { describe, expect, it } from 'vitest'
+
+import { StatusRule } from '../components/appChrome.js'
+import { SessionPanel } from '../components/branding.js'
+import { stripAnsi } from '../lib/text.js'
+import { DEFAULT_THEME, fromSkin } from '../theme.js'
+import type { SessionInfo } from '../types.js'
+
+const TAG_SKIN = resolve(import.meta.dirname, '../../../../tag/src/tag/assets/skins/tag-control.yaml')
+
+const extractBlockScalar = (source: string, key: string) => {
+  const marker = `${key}: |`
+  const start = source.indexOf(marker)
+
+  if (start === -1) {
+    throw new Error(`Missing block scalar: ${key}`)
+  }
+
+  const lines = source.slice(start + marker.length).split('\n').slice(1)
+  const collected: string[] = []
+
+  for (const line of lines) {
+    if (!line.startsWith('  ')) {
+      break
+    }
+    collected.push(line.slice(2))
+  }
+
+  return collected.join('\n')
+}
+
+const renderToText = (node: React.ReactElement, columns: number) => {
+  const stdout = new PassThrough()
+  const stdin = new PassThrough()
+  const stderr = new PassThrough()
+  let output = ''
+
+  Object.assign(stdout, { columns, isTTY: false, rows: 24 })
+  Object.assign(stdin, { isTTY: false })
+  Object.assign(stderr, { isTTY: false })
+  stdout.on('data', chunk => {
+    output += chunk.toString()
+  })
+
+  const instance = renderSync(node, {
+    patchConsole: false,
+    stderr: stderr as NodeJS.WriteStream,
+    stdin: stdin as NodeJS.ReadStream,
+    stdout: stdout as NodeJS.WriteStream
+  })
+
+  instance.unmount()
+  instance.cleanup()
+
+  return stripAnsi(output)
+    .replace(/\r/g, '')
+    .split('\n')
+    .filter(Boolean)
+}
+
+const skinDoc = readFileSync(TAG_SKIN, 'utf8')
+const bannerHero = extractBlockScalar(skinDoc, 'banner_hero')
+
+const panelInfo: SessionInfo = {
+  cwd: '/tmp/tag',
+  model: 'openrouter/deepseek/deepseek-v4-flash',
+  profile_name: 'researcher',
+  skills: { core: ['routing', 'verification'] },
+  tools: { shell_tools: ['exec', 'read'] },
+  version: '0.15.1'
+}
+
+const statusProps = {
+  bgCount: 0,
+  busy: false,
+  cols: 120,
+  cwdLabel: '~/tag',
+  liveSessionCount: 0,
+  model: 'openrouter/deepseek/deepseek-v4-flash',
+  sessionStartedAt: null,
+  showCost: false,
+  status: 'ready',
+  statusColor: DEFAULT_THEME.color.ok,
+  t: DEFAULT_THEME,
+  turnStartedAt: null,
+  usage: { context_max: 200_000, context_percent: 25, context_used: 50_000, total: 50_000 },
+  voiceLabel: ''
+}
+
+function StatusHarness({ cols }: { cols: number }) {
+  return StatusRule({ ...statusProps, cols })
+}
+
+describe('TAG banner hero layout', () => {
+  it('stays within the available banner width at 40 and 120 columns', () => {
+    const theme = fromSkin({}, {}, undefined, bannerHero)
+
+    for (const columns of [40, 120]) {
+      const lines = renderToText(
+        React.createElement(SessionPanel, {
+          info: panelInfo,
+          sid: 'session-123',
+          t: theme
+        }),
+        columns
+      )
+      const maxWidth = Math.max(...lines.map(line => line.length))
+
+      expect(maxWidth).toBeLessThanOrEqual(columns)
+      if (columns === 120) {
+        expect(lines.join('\n')).toContain('TAG')
+        expect(lines.join('\n')).toContain('CONTROL')
+        expect(lines.join('\n')).toContain('AGENTS')
+      }
+    }
+  })
+})
+
+describe('Status bar resize stress', () => {
+  it('survives 100 rapid narrow/wide rerenders without freezing', () => {
+    const stdout = new PassThrough()
+    const stdin = new PassThrough()
+    const stderr = new PassThrough()
+    let output = ''
+
+    Object.assign(stdout, { columns: 120, isTTY: false, rows: 24 })
+    Object.assign(stdin, { isTTY: false })
+    Object.assign(stderr, { isTTY: false })
+    stdout.on('data', chunk => {
+      output += chunk.toString()
+    })
+
+    const instance = renderSync(React.createElement(StatusHarness, { cols: 120 }), {
+      patchConsole: false,
+      stderr: stderr as NodeJS.WriteStream,
+      stdin: stdin as NodeJS.ReadStream,
+      stdout: stdout as NodeJS.WriteStream
+    })
+
+    const started = Date.now()
+    for (let i = 0; i < 100; i += 1) {
+      const cols = i % 2 === 0 ? 40 : 120
+      Object.assign(stdout, { columns: cols, rows: cols === 40 ? 24 : 30 })
+      instance.rerender(React.createElement(StatusHarness, { cols }))
+    }
+    const elapsedMs = Date.now() - started
+
+    instance.unmount()
+    instance.cleanup()
+
+    const rendered = stripAnsi(output)
+
+    expect(rendered).toContain('ready')
+    expect(rendered).toContain('deepseek v4 flash')
+    expect(elapsedMs).toBeLessThan(2000)
+  })
+})
